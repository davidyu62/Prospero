# Prospero_collector 환경변수
# application.properties 참조 - cp .env.example .env 후 값 채우기

# FRED API (매크로 데이터용)
FRED_API_KEY=your-fred-api-key

# Alpha Vantage (향후 RSI 등 확장용)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Glassnode (향후 온체인 지표 확장용)
GLASSNODE_API_KEY=demo

# CryptoQuant (향후 미결제 약정 확장용)
CRYPTOQUANT_API_KEY=demo

# Binance (선물 등 확장 시)
BINANCE_API_KEY=your-binance-key
BINANCE_SECRET_KEY=your-binance-secret

# AWS (DynamoDB 저장용)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=ap-northeast-2

# DynamoDB 테이블 (선택)
# DYNAMODB_CRYPTO_TABLE=TB_CRYPTO_DATA
# DYNAMODB_MACRO_TABLE=TB_MACRO_DATA
