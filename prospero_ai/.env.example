# Prospero AI - 환경 변수 설정 예시
# .env 파일을 생성하고 아래 값들을 설정하세요

# OpenAI API 키 (필수)
OPENAI_API_KEY=sk-...

# AWS DynamoDB 설정 (기본값: 아래 테이블명 사용)
DYNAMODB_CRYPTO_TABLE=TB_CRYPTO_DATA
DYNAMODB_MACRO_TABLE=TB_MACRO_DATA
DYNAMODB_AI_TABLE=TB_AI_INSIGHT

# AWS 리전 (기본값: ap-northeast-2)
AWS_DEFAULT_REGION=ap-northeast-2

# AWS 자격증명 (선택사항 - EC2 IAM 역할 사용 시 불필요)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# 로컬 테스트 시 사용
# run_local.py를 실행할 때: python run_local.py [yyyyMMdd]
# 또는 환경 변수로 설정: export OPENAI_API_KEY=sk-...
